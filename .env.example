JWT_SECRET=__CHANGE_ME__   # REQUIRED: generate with: openssl rand -hex 32  (min 32 chars in production)
DATABASE_URL=file:/data/voltlist.db
CARS_PATH=data/cars.json
PORT=8080
NODE_ENV=production
# Mark the auth cookie Secure (HTTPS-only). Leave false for plain-HTTP LAN access;
# set true only when serving behind HTTPS/TLS.
COOKIE_SECURE=false
